{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sync-quotes",
      "schedule": "0 3 * * *"
    }
  ],
  "buildCommand": "npm run sync:quotes && next build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://vercel.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://vercel.com"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
