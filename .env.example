# Notion quotes sync
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# extra control over you notion database for seprating personal/public views (e.g. quotes, notes, todo, etc)  
NEXT_PUBLIC_QUOTES_ADMIN_KEY=secret_passkey
ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weather widget
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel quote-sync automation
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/xxxxx/xxxx
CRON_SECRET=replace-with-a-random-16-plus-character-secret

# SEO canonical base URL
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Search Console site verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=ScLbPuILYWTWtNMP4oWQnBpW2VF037R5IA7QfrSvxyU

# Other for building private pages
ADMIN_USERNAME=admin_username
ADMIN_PASSWORD=admin_pass
ADMIN_NAME=admin_name
DATABASE_URL=postgresql://neondb_owner:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.....
VERCEL_AUTOMATION_BYPASS_SECRET=optional